# Build stage
FROM golang:1.26-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git

# go.sum* glob tolerates projects where go.sum does not yet exist
COPY go.mod go.sum* ./
RUN go mod download

COPY . .

# Build binary — auto-detect simple kit (main.go in root) vs multi kit (cmd/)
RUN if [ -f main.go ]; then \
      CGO_ENABLED=0 GOOS=linux go build -o main .; \
    else \
      CGO_ENABLED=0 GOOS=linux go build -o main ./cmd/*; \
    fi

# Runtime stage
FROM alpine:3.21

{{- if eq .Backup "litestream" }}
RUN apk --no-cache add ca-certificates tzdata wget
{{- else }}
RUN apk --no-cache add ca-certificates tzdata
{{- end }}
{{- if eq .Backup "litestream" }}

# Install Litestream with architecture-specific checksum verification
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then \
      LS_ARCH="arm64"; \
      LS_HASH="9585f5a508516bd66af2b2376bab4de256a5ef8e2b73ec760559e679628f2d59"; \
    else \
      LS_ARCH="amd64"; \
      LS_HASH="eb75a3de5cab03875cdae9f5f539e6aedadd66607003d9b1e7a9077948818ba0"; \
    fi && \
    wget https://github.com/benbjohnson/litestream/releases/download/v0.3.13/litestream-v0.3.13-linux-${LS_ARCH}.tar.gz && \
    echo "${LS_HASH}  litestream-v0.3.13-linux-${LS_ARCH}.tar.gz" | sha256sum -c - && \
    tar -C /usr/local/bin -xzf litestream-v0.3.13-linux-${LS_ARCH}.tar.gz && \
    rm litestream-v0.3.13-linux-${LS_ARCH}.tar.gz
{{- end }}

WORKDIR /app

COPY --from=builder /app/main .
COPY --from=builder /app/app ./app
{{- if ne .Database "none" }}
# Requires database/schema.sql and database/migrations/ in the project
COPY --from=builder /app/database/schema.sql ./database/schema.sql
COPY --from=builder /app/database/migrations ./database/migrations
{{- end }}
{{- if eq .Backup "litestream" }}
COPY deploy/litestream.yml /etc/litestream.yml
{{- end }}
{{- if eq .Database "sqlite" }}

# Create data directory for SQLite (Fly volume mount point)
RUN mkdir -p /data

ENV DATABASE_PATH=/data/app.db
{{- end }}

ENV PORT=8080

EXPOSE 8080
{{- if eq .Backup "litestream" }}

CMD litestream replicate -config /etc/litestream.yml -exec "./main"
{{- else }}

CMD ["./main"]
{{- end }}
