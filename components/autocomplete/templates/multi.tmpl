{{define "lvt:autocomplete:multi:v1"}}
<div class="{{.Styles.Root}}" data-autocomplete="{{.ID}}" data-multi="true">
  <div class="{{.Styles.InputWrapper}}">
    {{range .SelectedItems}}
    <span class="{{$.Styles.OptionLabel}}">
      {{.Label}}
      <button
        type="button"
        class="{{$.Styles.ClearIcon}}"
        lvt-click="remove_{{$.ID}}"
        lvt-data-value="{{.Value}}"
        aria-label="Remove {{.Label}}"
      >
        <svg class="{{$.Styles.ClearIcon}}" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </span>
    {{end}}
    <input
      type="text"
      class="{{.Styles.Input}}"
      placeholder="{{if .HasSelectedItems}}{{else}}{{.Placeholder}}{{end}}"
      value="{{.Query}}"
      lvt-input="query_{{.ID}}"
      lvt-focus="focus_{{.ID}}"
      lvt-keydown="keydown_{{.ID}}"
      autocomplete="off"
      aria-autocomplete="list"
      aria-haspopup="listbox"
      aria-expanded="{{.Open}}"
    />
    {{if .Loading}}
    <div class="{{.Styles.LoadingWrapper}}">
      <svg class="{{.Styles.LoadingIcon}}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </div>
    {{else if .HasSelectedItems}}
    <button
      type="button"
      class="{{.Styles.ClearBtn}}"
      lvt-click="clear_multi_{{.ID}}"
      aria-label="Clear all"
    >
      <svg class="{{.Styles.ClearIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    {{end}}
  </div>

  {{if .Open}}
  <ul
    class="{{.Styles.Dropdown}}"
    role="listbox"
    lvt-click-away="blur_{{.ID}}"
  >
    {{$filtered := .FilteredExcludingSelected}}
    {{range $index, $suggestion := $filtered}}
    <li
      class="{{$.Styles.Option}} {{if $suggestion.Disabled}}{{$.Styles.OptionDisabled}}{{else if $.IsHighlighted $index}}{{$.Styles.OptionActive}}{{end}}"
      role="option"
      {{if not $suggestion.Disabled}}
      lvt-click="select_multi_{{$.ID}}"
      lvt-data-value="{{$suggestion.Value}}"
      {{end}}
      {{if $suggestion.Disabled}}aria-disabled="true"{{end}}
    >
      <div class="{{$.Styles.OptionLayout}}">
        {{if $suggestion.Icon}}
        <span class="{{$.Styles.OptionIcon}}">{{$suggestion.Icon}}</span>
        {{end}}
        <div>
          <div class="{{$.Styles.OptionLabel}}">{{$suggestion.Label}}</div>
          {{if $suggestion.Description}}
          <div class="{{if $.IsHighlighted $index}}{{$.Styles.OptionDescAlt}}{{else}}{{$.Styles.OptionDesc}}{{end}}">{{$suggestion.Description}}</div>
          {{end}}
        </div>
      </div>
    </li>
    {{else}}
    <li class="{{$.Styles.Empty}}">No suggestions found</li>
    {{end}}
  </ul>
  {{end}}
</div>
{{end}}
