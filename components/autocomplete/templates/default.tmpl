{{define "lvt:autocomplete:default:v1"}}
{{$c := .}}
<style>[data-autocomplete]:not(.open) [data-autocomplete-panel]{display:none}</style>
<div class="{{$c.Styles.Root}} {{if $c.Open}}open{{end}}" data-autocomplete="{{$c.ID}}"
     lvt-el:removeClass:on:click-away="open">
  <div class="{{$c.Styles.InputWrapper}}">
    <input
      type="text"
      class="{{$c.Styles.Input}} {{if $c.Loading}}{{$c.Styles.InputLoading}}{{end}}"
      placeholder="{{$c.Placeholder}}"
      value="{{$c.Query}}"
      lvt-on:input="query_{{$c.ID}}"
      onfocus="this.closest('[data-autocomplete]').classList.add('open')"
      lvt-on:keydown="keydown_{{$c.ID}}"
      autocomplete="off"
      aria-autocomplete="list"
      aria-haspopup="listbox"
      aria-expanded="{{$c.Open}}"
      aria-controls="suggestions_{{$c.ID}}"
    />
    {{if $c.Loading}}
    <div class="{{$c.Styles.LoadingWrapper}}">
      <svg class="{{$c.Styles.LoadingIcon}}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </div>
    {{else if $c.HasSelection}}
    <button
      type="button"
      class="{{$c.Styles.ClearBtn}}"
      name="clear_{{$c.ID}}"
      aria-label="Clear selection"
    >
      <svg class="{{$c.Styles.ClearIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    {{end}}
  </div>

  <ul
    id="suggestions_{{$c.ID}}"
    class="{{$c.Styles.Dropdown}}"
    data-autocomplete-panel
    role="listbox"
  >
    {{range $index, $suggestion := $c.FilteredSuggestions}}
    <li
      class="{{$c.Styles.Option}} {{if $suggestion.Disabled}}{{$c.Styles.OptionDisabled}}{{else if $c.IsHighlighted $index}}{{$c.Styles.OptionActive}}{{end}}"
      role="option"
      {{if not $suggestion.Disabled}}
      lvt-on:click="select_{{$c.ID}}"
      data-index="{{$index}}"
      {{end}}
      aria-selected="{{$c.IsHighlighted $index}}"
      {{if $suggestion.Disabled}}aria-disabled="true"{{end}}
    >
      <div class="{{$c.Styles.OptionLayout}}">
        {{if $suggestion.Icon}}
        <span class="{{$c.Styles.OptionIcon}}">{{$suggestion.Icon}}</span>
        {{end}}
        <div>
          <div class="{{$c.Styles.OptionLabel}}">{{$suggestion.Label}}</div>
          {{if $suggestion.Description}}
          <div class="{{if $c.IsHighlighted $index}}{{$c.Styles.OptionDescAlt}}{{else}}{{$c.Styles.OptionDesc}}{{end}}">{{$suggestion.Description}}</div>
          {{end}}
        </div>
      </div>
    </li>
    {{else}}
    <li class="{{$c.Styles.Empty}}">No suggestions found</li>
    {{end}}
  </ul>
</div>
{{end}}
