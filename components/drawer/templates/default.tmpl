{{define "lvt:drawer:default:v1"}}
<style>
[data-drawer]:not(.open){pointer-events:none}
[data-drawer]:not(.open) [data-drawer-overlay]{opacity:0}
[data-drawer]:not(.open) [data-drawer-panel]{transform:var(--drawer-closed-transform)}
[data-drawer].open [data-drawer-panel]{transform:translate(0,0)}
</style>
<div class="{{.Styles.Root}}" data-drawer="{{.ID}}"
     style="--drawer-closed-transform:{{.TransformClass}}"
     {{if .Persistent}}data-persistent="true"{{end}}>
  {{/* Overlay */}}
  {{if .ShowOverlay}}
  <div
    class="{{.Styles.Overlay}}"
    data-drawer-overlay
    {{if .CloseOnOverlay}}onclick="var d=this.closest('[data-drawer]');if(!d.hasAttribute('data-persistent'))d.classList.remove('open')"{{end}}
    aria-hidden="true"
  ></div>
  {{end}}

  {{/* Drawer panel */}}
  <div
    class="{{.Styles.PanelBase}} {{.PositionClass}} {{.SizeClass}}"
    data-drawer-panel
    role="dialog"
    aria-modal="true"
    {{if .HasTitle}}aria-labelledby="drawer-title-{{.ID}}"{{end}}
  >
    {{/* Header */}}
    {{if or .HasTitle .ShowClose}}
    <div class="{{.Styles.Header}}">
      {{if .HasTitle}}
      <h2 id="drawer-title-{{.ID}}" class="{{.Styles.Title}}">{{.Title}}</h2>
      {{else}}
      <div></div>
      {{end}}
      {{if .ShowClose}}
      <button
        type="button"
        class="{{.Styles.CloseBtn}}"
        onclick="var d=this.closest('[data-drawer]');if(!d.hasAttribute('data-persistent'))d.classList.remove('open')"
        aria-label="Close drawer"
      >
        <svg class="{{.Styles.CloseIcon}}" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
      {{end}}
    </div>
    {{end}}

    {{/* Content - use slot/block in actual usage */}}
    <div class="{{.Styles.Content}}">
      {{/* Content is rendered by the parent template using nested template or slot */}}
    </div>
  </div>
</div>
{{end}}
