{{define "lvt:drawer:default:v1"}}
{{if .Open}}
<div class="{{.Styles.Root}}" data-drawer="{{.ID}}">
  {{/* Overlay */}}
  {{if .ShowOverlay}}
  <div
    class="{{.Styles.Overlay}}"
    {{if .CloseOnOverlay}}lvt-click="close_{{.ID}}"{{end}}
    aria-hidden="true"
  ></div>
  {{end}}

  {{/* Drawer panel */}}
  <div
    class="{{.Styles.PanelBase}} {{.PositionClass}} {{.SizeClass}} {{.TransformClass}}"
    role="dialog"
    aria-modal="true"
    {{if .HasTitle}}aria-labelledby="drawer-title-{{.ID}}"{{end}}
  >
    {{/* Header */}}
    {{if or .HasTitle .ShowClose}}
    <div class="{{.Styles.Header}}">
      {{if .HasTitle}}
      <h2 id="drawer-title-{{.ID}}" class="{{.Styles.Title}}">{{.Title}}</h2>
      {{else}}
      <div></div>
      {{end}}
      {{if .ShowClose}}
      <button
        type="button"
        class="{{.Styles.CloseBtn}}"
        lvt-click="close_{{.ID}}"
        aria-label="Close drawer"
      >
        <svg class="{{.Styles.CloseIcon}}" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
      {{end}}
    </div>
    {{end}}

    {{/* Content - use slot/block in actual usage */}}
    <div class="{{.Styles.Content}}">
      {{/* Content is rendered by the parent template using nested template or slot */}}
    </div>
  </div>
</div>
{{end}}
{{end}}
