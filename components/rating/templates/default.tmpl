{{define "lvt:rating:default:v1"}}
{{$c := .}}
<div class="{{$c.Styles.Root}}" data-rating="{{$c.ID}}">
  {{if $c.Label}}
  <span class="{{$c.Styles.Label}}">{{$c.Label}}</span>
  {{end}}

  <div
    class="{{$c.Styles.StarsWrapper}} {{$c.SizeClass}} {{if not $c.Readonly}}{{$c.Styles.StarBtn}}{{else}}{{$c.Styles.StarReadonly}}{{end}}"
    {{if not $c.Readonly}}lvt-on:mouseleave="leave_{{$c.ID}}"{{end}}
  >
    {{range $star := $c.Stars}}
    <span
      class="{{if $c.IsStarFull $star}}{{$c.ColorClass}}{{else if $c.IsStarHalf $star}}{{$c.ColorClass}}{{else}}{{$c.EmptyColorClass}}{{end}}"
      {{if not $c.Readonly}}
      lvt-on:click="click_{{$c.ID}}"
      data-star="{{$star}}"
      lvt-on:mouseover="hover_{{$c.ID}}"
      {{end}}
    >
      {{if $c.IsStarHalf $star}}
      <span class="{{$c.Styles.HalfStarOuter}}">
        <span class="{{$c.Styles.HalfStarInner}}" style="width: 50%">{{$c.Character}}</span>
        <span class="{{$c.EmptyColorClass}}">{{$c.Character}}</span>
      </span>
      {{else}}
      {{$c.Character}}
      {{end}}
    </span>
    {{end}}
  </div>

  {{if $c.ShowValue}}
  <span class="{{$c.Styles.ValueText}}">{{$c.FormatValue}}</span>
  {{end}}

  {{if and $c.ShowCount (gt $c.Count 0)}}
  <span class="{{$c.Styles.CountText}}">({{$c.Count}})</span>
  {{end}}
</div>
{{end}}
