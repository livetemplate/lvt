{{define "lvt:rating:default:v1"}}
<div class="{{.Styles.Root}}" data-rating="{{.ID}}">
  {{if .Label}}
  <span class="{{.Styles.Label}}">{{.Label}}</span>
  {{end}}

  <div
    class="{{.Styles.StarsWrapper}} {{.SizeClass}} {{if not .Readonly}}{{.Styles.StarBtn}}{{else}}{{.Styles.StarReadonly}}{{end}}"
    {{if not .Readonly}}lvt-mouseleave="leave_{{.ID}}"{{end}}
  >
    {{range $star := .Stars}}
    <span
      class="{{if $.IsStarFull $star}}{{$.ColorClass}}{{else if $.IsStarHalf $star}}{{$.ColorClass}}{{else}}{{$.EmptyColorClass}}{{end}}"
      {{if not $.Readonly}}
      lvt-click="click_{{$.ID}}"
      lvt-data-star="{{$star}}"
      lvt-mouseover="hover_{{$.ID}}"
      {{end}}
    >
      {{if $.IsStarHalf $star}}
      <span class="{{$.Styles.HalfStarOuter}}">
        <span class="{{$.Styles.HalfStarInner}}" style="width: 50%">{{$.Character}}</span>
        <span class="{{$.EmptyColorClass}}">{{$.Character}}</span>
      </span>
      {{else}}
      {{$.Character}}
      {{end}}
    </span>
    {{end}}
  </div>

  {{if .ShowValue}}
  <span class="{{.Styles.ValueText}}">{{.FormatValue}}</span>
  {{end}}

  {{if and .ShowCount (gt .Count 0)}}
  <span class="{{.Styles.CountText}}">({{.Count}})</span>
  {{end}}
</div>
{{end}}
