{{define "lvt:rating:readonly:v1"}}
{{$c := .}}
<div class="{{$c.Styles.Root}}" data-rating="{{$c.ID}}" data-readonly="true">
  {{if $c.Label}}
  <span class="{{$c.Styles.Label}}">{{$c.Label}}</span>
  {{end}}

  <div class="{{$c.Styles.StarsWrapper}} {{$c.SizeClass}}">
    {{range $star := $c.Stars}}
    <span class="{{if $c.IsStarFull $star}}{{$c.ColorClass}}{{else if $c.IsStarHalf $star}}{{$c.ColorClass}}{{else}}{{$c.EmptyColorClass}}{{end}}">
      {{if $c.IsStarHalf $star}}
      <span class="{{$c.Styles.HalfStarOuter}}">
        <span class="{{$c.Styles.HalfStarInner}}" style="width: 50%">{{$c.Character}}</span>
        <span class="{{$c.EmptyColorClass}}">{{$c.Character}}</span>
      </span>
      {{else}}
      {{$c.Character}}
      {{end}}
    </span>
    {{end}}
  </div>

  {{if $c.ShowValue}}
  <span class="{{$c.Styles.ValueText}}">{{$c.FormatValue}}</span>
  {{end}}

  {{if and $c.ShowCount (gt $c.Count 0)}}
  <span class="{{$c.Styles.CountText}}">({{$c.Count}} reviews)</span>
  {{end}}
</div>
{{end}}
