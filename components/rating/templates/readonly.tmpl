{{define "lvt:rating:readonly:v1"}}
<div class="{{.Styles.Root}}" data-rating="{{.ID}}" data-readonly="true">
  {{if .Label}}
  <span class="{{.Styles.Label}}">{{.Label}}</span>
  {{end}}

  <div class="{{.Styles.StarsWrapper}} {{.SizeClass}}">
    {{range $star := .Stars}}
    <span class="{{if $.IsStarFull $star}}{{$.ColorClass}}{{else if $.IsStarHalf $star}}{{$.ColorClass}}{{else}}{{$.EmptyColorClass}}{{end}}">
      {{if $.IsStarHalf $star}}
      <span class="{{$.Styles.HalfStarOuter}}">
        <span class="{{$.Styles.HalfStarInner}}" style="width: 50%">{{$.Character}}</span>
        <span class="{{$.EmptyColorClass}}">{{$.Character}}</span>
      </span>
      {{else}}
      {{$.Character}}
      {{end}}
    </span>
    {{end}}
  </div>

  {{if .ShowValue}}
  <span class="{{.Styles.ValueText}}">{{.FormatValue}}</span>
  {{end}}

  {{if and .ShowCount (gt .Count 0)}}
  <span class="{{.Styles.CountText}}">({{.Count}} reviews)</span>
  {{end}}
</div>
{{end}}
