{{define "lvt:popover:default:v1"}}
<div class="{{.Styles.Root}}" data-popover="{{.ID}}">
  {{/* Trigger element wrapper */}}
  <div
    {{if .IsClickTrigger}}
    lvt-click="toggle_{{.ID}}"
    {{end}}
    {{if .IsHoverTrigger}}
    lvt-mouseenter="show_{{.ID}}"
    lvt-mouseleave="hide_{{.ID}}"
    {{end}}
    {{if .IsFocusTrigger}}
    lvt-focus="show_{{.ID}}"
    lvt-blur="hide_{{.ID}}"
    {{end}}
  >
    {{/* Slot for trigger content */}}
  </div>

  {{/* Popover content */}}
  {{if .Open}}
  <div
    class="{{.Styles.Panel}} {{.PositionClasses}}"
    style="width: {{.Width}}"
    role="dialog"
    {{if .CloseOnClickAway}}lvt-click-away="hide_{{.ID}}"{{end}}
  >
    {{/* Header */}}
    {{if .HasHeader}}
    <div class="{{.Styles.Header}}">
      {{if .HasTitle}}
      <h3 class="{{.Styles.Title}}">{{.Title}}</h3>
      {{else}}
      <div></div>
      {{end}}
      {{if .ShowClose}}
      <button
        type="button"
        class="{{.Styles.CloseBtn}}"
        lvt-click="hide_{{.ID}}"
        aria-label="Close"
      >
        <svg class="{{.Styles.CloseIcon}}" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
      {{end}}
    </div>
    {{end}}

    {{/* Body */}}
    <div class="{{.Styles.Body}}">
      {{if .HasContent}}{{.Content}}{{end}}
      {{/* Additional content slot */}}
    </div>

    {{/* Arrow */}}
    {{if .Arrow}}
    <div class="{{.ArrowClasses}}"></div>
    {{end}}
  </div>
  {{end}}
</div>
{{end}}
