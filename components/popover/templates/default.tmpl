{{define "lvt:popover:default:v1"}}
<style>[data-popover]:not(.open) [data-popover-panel]{display:none}</style>
<div class="{{.Styles.Root}}" data-popover="{{.ID}}"
     {{if .CloseOnClickAway}}lvt-el:removeClass:on:click-away="open"{{end}}>
  {{/* Trigger element wrapper */}}
  <div
    {{if .IsClickTrigger}}
    onclick="var r=this.closest('[data-popover]');r.classList.toggle('open')"
    {{end}}
    {{if .IsHoverTrigger}}
    onmouseenter="this.closest('[data-popover]').classList.add('open')"
    onmouseleave="this.closest('[data-popover]').classList.remove('open')"
    {{end}}
    {{if .IsFocusTrigger}}
    onfocus="this.closest('[data-popover]').classList.add('open')"
    onblur="this.closest('[data-popover]').classList.remove('open')"
    {{end}}
  >
    {{/* Slot for trigger content */}}
  </div>

  {{/* Popover content */}}
  <div
    class="{{.Styles.Panel}} {{.PositionClasses}}"
    style="width: {{.Width}}"
    role="dialog"
    data-popover-panel
  >
    {{/* Header */}}
    {{if .HasHeader}}
    <div class="{{.Styles.Header}}">
      {{if .HasTitle}}
      <h3 class="{{.Styles.Title}}">{{.Title}}</h3>
      {{else}}
      <div></div>
      {{end}}
      {{if .ShowClose}}
      <button
        type="button"
        class="{{.Styles.CloseBtn}}"
        onclick="this.closest('[data-popover]').classList.remove('open')"
        aria-label="Close"
      >
        <svg class="{{.Styles.CloseIcon}}" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
      {{end}}
    </div>
    {{end}}

    {{/* Body */}}
    <div class="{{.Styles.Body}}">
      {{if .HasContent}}{{.Content}}{{end}}
      {{/* Additional content slot */}}
    </div>

    {{/* Arrow */}}
    {{if .Arrow}}
    <div class="{{.ArrowClasses}}"></div>
    {{end}}
  </div>
</div>
{{end}}
