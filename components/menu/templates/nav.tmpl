{{define "lvt:menu:nav:v1"}}
{{$c := .}}
<style>[data-submenu]:not(.open)>[data-submenu-panel]{display:none}</style>
<nav class="{{if eq $c.Orientation "vertical"}}flex flex-col space-y-1{{else}}flex items-center space-x-1{{end}}" data-menu="{{$c.ID}}" data-nav="true">
  {{range $item := $c.Items}}
  {{if $item.IsDivider}}
  {{if eq $c.Orientation "vertical"}}
  <hr class="{{$c.Styles.Divider}}" />
  {{else}}
  <div class="h-6 w-px bg-gray-200"></div>
  {{end}}
  {{else if $item.IsHeader}}
  <div class="{{$c.Styles.SectionHeader}}">
    {{$item.Label}}
  </div>
  {{else if $item.IsSubmenu}}
  <div class="relative" data-submenu="{{$item.ID}}"
       lvt-el:removeClass:on:click-away="open">
    <button
      type="button"
      class="{{$c.Styles.Item}} {{if $item.Active}}{{$c.Styles.ItemActive}}{{else}}{{$c.Styles.ItemDefault}}{{end}}"
      lvt-el:toggleClass:on:click="open" data-lvt-target="closest:[data-submenu]"
      aria-haspopup="true"
    >
      {{if $item.HasIcon}}<span>{{$item.Icon}}</span>{{end}}
      {{$item.Label}}
      <svg class="{{$c.Styles.TriggerIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    <div
      class="{{if eq $c.Orientation "vertical"}}pl-4 mt-1 space-y-1{{else}}{{$c.Styles.Panel}}{{end}}"
      data-submenu-panel
    >
      {{range $subItem := $item.Items}}
      {{if $subItem.IsLink}}
      <a
        href="{{$subItem.Href}}"
        {{if $subItem.Target}}target="{{$subItem.Target}}"{{end}}
        class="{{$c.Styles.Item}} {{if $subItem.Active}}{{$c.Styles.ItemActive}}{{else if $subItem.Disabled}}{{$c.Styles.ItemDisabled}}{{else}}{{$c.Styles.ItemDefault}}{{end}}"
      >
        {{if $subItem.HasIcon}}<span class="mr-2">{{$subItem.Icon}}</span>{{end}}
        {{$subItem.Label}}
      </a>
      {{else}}
      <button
        type="button"
        class="{{$c.Styles.Item}} w-full text-left {{if $subItem.Active}}{{$c.Styles.ItemActive}}{{else if $subItem.Disabled}}{{$c.Styles.ItemDisabled}}{{else}}{{$c.Styles.ItemDefault}}{{end}}"
        {{if not $subItem.Disabled}}
        name="select_{{$c.ID}}"
        data-item="{{$subItem.ID}}"
        {{end}}
        {{if $subItem.Disabled}}disabled{{end}}
      >
        {{if $subItem.HasIcon}}<span class="mr-2">{{$subItem.Icon}}</span>{{end}}
        {{$subItem.Label}}
      </button>
      {{end}}
      {{end}}
    </div>
  </div>
  {{else if $item.IsLink}}
  <a
    href="{{$item.Href}}"
    {{if $item.Target}}target="{{$item.Target}}"{{end}}
    class="{{$c.Styles.Item}} {{if $item.Active}}{{$c.Styles.ItemActive}}{{else if $item.Disabled}}{{$c.Styles.ItemDisabled}}{{else}}{{$c.Styles.ItemDefault}}{{end}}"
    {{if $item.Disabled}}aria-disabled="true"{{end}}
  >
    {{if $item.HasIcon}}<span>{{$item.Icon}}</span>{{end}}
    {{$item.Label}}
    {{if $item.HasBadge}}
    <span class="{{$c.Styles.Badge}} {{$c.BadgeClass $item.BadgeColor}}">
      {{$item.Badge}}
    </span>
    {{end}}
  </a>
  {{else}}
  <button
    type="button"
    class="{{$c.Styles.Item}} {{if $item.Active}}{{$c.Styles.ItemActive}}{{else if $item.Disabled}}{{$c.Styles.ItemDisabled}}{{else}}{{$c.Styles.ItemDefault}}{{end}}"
    {{if not $item.Disabled}}
    name="select_{{$c.ID}}"
    data-item="{{$item.ID}}"
    {{end}}
    {{if $item.Disabled}}disabled{{end}}
  >
    {{if $item.HasIcon}}<span>{{$item.Icon}}</span>{{end}}
    {{$item.Label}}
    {{if $item.HasBadge}}
    <span class="{{$c.Styles.Badge}} {{$c.BadgeClass $item.BadgeColor}}">
      {{$item.Badge}}
    </span>
    {{end}}
  </button>
  {{end}}
  {{end}}
</nav>
{{end}}
