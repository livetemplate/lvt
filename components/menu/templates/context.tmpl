{{define "lvt:menu:context:v1"}}
{{if .Open}}
<div
  class="{{.Styles.Panel}}"
  style="position: fixed; left: {{.X}}px; top: {{.Y}}px; z-index: 50;"
  role="menu"
  data-menu="{{.ID}}"
  data-context="true"
  lvt-click-away="close_{{.ID}}"
>
  <div class="{{.Styles.PanelInner}}">
    {{range $index, $item := .Items}}
    {{if $item.IsDivider}}
    <hr class="{{$.Styles.Divider}}" />
    {{else if $item.IsHeader}}
    <div class="{{$.Styles.SectionHeader}}">
      {{$item.Label}}
    </div>
    {{else}}
    <button
      type="button"
      class="{{$.Styles.Item}} w-full text-left {{$.ItemClass $item}}"
      role="menuitem"
      {{if not $item.Disabled}}
      lvt-click="select_{{$.ID}}"
      lvt-data-item="{{$item.ID}}"
      {{end}}
      {{if $item.Disabled}}disabled aria-disabled="true"{{end}}
    >
      <span class="flex items-center gap-2">
        {{if $item.HasIcon}}<span class="{{$.Styles.ItemIcon}}">{{$item.Icon}}</span>{{end}}
        <span>{{$item.Label}}</span>
      </span>
      {{if $item.HasShortcut}}
      <span class="{{$.Styles.Shortcut}}">{{$item.Shortcut}}</span>
      {{end}}
    </button>
    {{end}}
    {{end}}
  </div>
</div>
{{end}}
{{end}}
