{{define "lvt:menu:context:v1"}}
{{$c := .}}
<style>[data-menu][data-context]:not(.open) [data-menu-panel]{display:none}</style>
<div
  data-menu="{{$c.ID}}"
  data-context="true"
  lvt-el:removeClass:on:click-away="open"
>
  <div
    class="{{$c.Styles.Panel}}"
    style="position: fixed; left: {{$c.X}}px; top: {{$c.Y}}px; z-index: 50;"
    role="menu"
    data-menu-panel
  >
    <div class="{{$c.Styles.PanelInner}}">
      {{range $index, $item := $c.Items}}
      {{if $item.IsDivider}}
      <hr class="{{$c.Styles.Divider}}" />
      {{else if $item.IsHeader}}
      <div class="{{$c.Styles.SectionHeader}}">
        {{$item.Label}}
      </div>
      {{else}}
      <button
        type="button"
        class="{{$c.Styles.Item}} w-full text-left {{$c.ItemClass $item}}"
        role="menuitem"
        {{if not $item.Disabled}}
        lvt-click="select_{{$c.ID}}"
        lvt-data-item="{{$item.ID}}"
        {{end}}
        {{if $item.Disabled}}disabled aria-disabled="true"{{end}}
      >
        <span class="flex items-center gap-2">
          {{if $item.HasIcon}}<span class="{{$c.Styles.ItemIcon}}">{{$item.Icon}}</span>{{end}}
          <span>{{$item.Label}}</span>
        </span>
        {{if $item.HasShortcut}}
        <span class="{{$c.Styles.Shortcut}}">{{$item.Shortcut}}</span>
        {{end}}
      </button>
      {{end}}
      {{end}}
    </div>
  </div>
</div>
{{end}}
