{{define "lvt:timepicker:duration:v1"}}
<style>[data-timepicker]:not(.open) [data-timepicker-panel]{display:none}</style>
<div class="{{.DurationStyles.Root}}" data-timepicker="{{.ID}}" data-duration="true"
     lvt-el:removeClass:on:click-away="open"
     lvt-el:addClass:on:done="open">
  <button
    type="button"
    class="{{.DurationStyles.TriggerBtn}}"
    onclick="var r=this.closest('[data-timepicker]');r.classList.toggle('open');this.setAttribute('aria-expanded',r.classList.contains('open'))"
    aria-haspopup="dialog"
    aria-expanded="false"
  >
    <span class="{{.DurationStyles.TriggerText}}">
      <span class="{{if not .HasValue}}{{.DurationStyles.Placeholder}}{{end}}">{{.DisplayValue}}</span>
      <svg class="{{.DurationStyles.TriggerIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
      </svg>
    </span>
  </button>

  <div
    class="{{.DurationStyles.Dropdown}}"
    data-timepicker-panel
    hidden
    role="dialog"
    aria-modal="true"
    aria-label="Choose duration"
  >
    <div class="{{.DurationStyles.SpinnerLayout}}">
      {{/* Hours */}}
      <div class="{{.DurationStyles.SpinnerCol}}">
        <span>Hours</span>
        <button
          type="button"
          class="{{.DurationStyles.SpinnerBtn}}"
          lvt-click="inc_hours_{{.ID}}"
          aria-label="Increment hours"
        >
          <svg class="{{.DurationStyles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <input
          type="text"
          class="{{.DurationStyles.SpinnerInput}}"
          value="{{.Hours}}"
          readonly
        />
        <button
          type="button"
          class="{{.DurationStyles.SpinnerBtn}}"
          lvt-click="dec_hours_{{.ID}}"
          aria-label="Decrement hours"
        >
          <svg class="{{.DurationStyles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>

      {{/* Minutes */}}
      <div class="{{.DurationStyles.SpinnerCol}}">
        <span>Minutes</span>
        <button
          type="button"
          class="{{.DurationStyles.SpinnerBtn}}"
          lvt-click="inc_minutes_{{.ID}}"
          aria-label="Increment minutes"
        >
          <svg class="{{.DurationStyles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <input
          type="text"
          class="{{.DurationStyles.SpinnerInput}}"
          value="{{printf "%02d" .Minutes}}"
          readonly
        />
        <button
          type="button"
          class="{{.DurationStyles.SpinnerBtn}}"
          lvt-click="dec_minutes_{{.ID}}"
          aria-label="Decrement minutes"
        >
          <svg class="{{.DurationStyles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>

      {{if .ShowSeconds}}
      {{/* Seconds */}}
      <div class="{{.DurationStyles.SpinnerCol}}">
        <span>Seconds</span>
        <button
          type="button"
          class="{{.DurationStyles.SpinnerBtn}}"
          lvt-click="inc_seconds_{{.ID}}"
          aria-label="Increment seconds"
        >
          <svg class="{{.DurationStyles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <input
          type="text"
          class="{{.DurationStyles.SpinnerInput}}"
          value="{{printf "%02d" .Seconds}}"
          readonly
        />
        <button
          type="button"
          class="{{.DurationStyles.SpinnerBtn}}"
          lvt-click="dec_seconds_{{.ID}}"
          aria-label="Decrement seconds"
        >
          <svg class="{{.DurationStyles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
      {{end}}
    </div>

    {{if .HasValue}}
    <div class="{{.DurationStyles.Footer}}">
      <button
        type="button"
        class="{{.DurationStyles.ClearBtn}}"
        lvt-click="clear_{{.ID}}"
      >
        Clear
      </button>
    </div>
    {{end}}
  </div>
</div>
{{end}}
