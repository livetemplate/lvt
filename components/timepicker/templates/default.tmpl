{{define "lvt:timepicker:default:v1"}}
{{template "lvt:timepicker:panel-css"}}
<div class="{{.Styles.Root}}" data-timepicker="{{.ID}}"
     lvt-el:removeClass:on:click-away="open"
     lvt-el:addClass:on:done="open">
  <button
    type="button"
    class="{{.Styles.TriggerBtn}}"
    onclick="var r=this.closest('[data-timepicker]');r.classList.toggle('open');this.setAttribute('aria-expanded',r.classList.contains('open'))"
    aria-haspopup="dialog"
    aria-expanded="false"
  >
    <span class="{{.Styles.TriggerText}}">
      <span class="{{if not .HasValue}}{{.Styles.Placeholder}}{{end}}">{{.DisplayValue}}</span>
      <svg class="{{.Styles.TriggerIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
      </svg>
    </span>
  </button>

  <div
    class="{{.Styles.Dropdown}}"
    data-timepicker-panel
    role="dialog"
    aria-modal="true"
    aria-label="Choose time"
  >
    <div class="{{.Styles.SpinnerLayout}}">
      {{/* Hour */}}
      <div class="{{.Styles.SpinnerCol}}">
        <button
          type="button"
          class="{{.Styles.SpinnerBtn}}"
          name="inc_hour_{{.ID}}"
          aria-label="Increment hour"
        >
          <svg class="{{.Styles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <input
          type="text"
          class="{{.Styles.SpinnerInput}}"
          value="{{if .Use24Hour}}{{printf "%02d" .Hour}}{{else}}{{.Hour}}{{end}}"
          readonly
        />
        <button
          type="button"
          class="{{.Styles.SpinnerBtn}}"
          name="dec_hour_{{.ID}}"
          aria-label="Decrement hour"
        >
          <svg class="{{.Styles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>

      <span class="{{.Styles.Separator}}">:</span>

      {{/* Minute */}}
      <div class="{{.Styles.SpinnerCol}}">
        <button
          type="button"
          class="{{.Styles.SpinnerBtn}}"
          name="inc_minute_{{.ID}}"
          aria-label="Increment minute"
        >
          <svg class="{{.Styles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <input
          type="text"
          class="{{.Styles.SpinnerInput}}"
          value="{{printf "%02d" .Minute}}"
          readonly
        />
        <button
          type="button"
          class="{{.Styles.SpinnerBtn}}"
          name="dec_minute_{{.ID}}"
          aria-label="Decrement minute"
        >
          <svg class="{{.Styles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>

      {{if .ShowSeconds}}
      <span class="{{.Styles.Separator}}">:</span>
      {{/* Second */}}
      <div class="{{.Styles.SpinnerCol}}">
        <button
          type="button"
          class="{{.Styles.SpinnerBtn}}"
          name="inc_second_{{.ID}}"
          aria-label="Increment second"
        >
          <svg class="{{.Styles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <input
          type="text"
          class="{{.Styles.SpinnerInput}}"
          value="{{printf "%02d" .Second}}"
          readonly
        />
        <button
          type="button"
          class="{{.Styles.SpinnerBtn}}"
          name="dec_second_{{.ID}}"
          aria-label="Decrement second"
        >
          <svg class="{{.Styles.SpinnerIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
      {{end}}

      {{if not .Use24Hour}}
      {{/* AM/PM */}}
      <div class="{{.Styles.PeriodCol}}">
        <button
          type="button"
          class="{{if eq .Period "AM"}}{{.Styles.PeriodActive}}{{else}}{{.Styles.PeriodDefault}}{{end}}"
          name="set_period_{{.ID}}"
          data-period="AM"
        >
          AM
        </button>
        <button
          type="button"
          class="mt-1 {{if eq .Period "PM"}}{{.Styles.PeriodActive}}{{else}}{{.Styles.PeriodDefault}}{{end}}"
          name="set_period_{{.ID}}"
          data-period="PM"
        >
          PM
        </button>
      </div>
      {{end}}
    </div>

    <div class="{{.Styles.Footer}}">
      <button
        type="button"
        class="{{.Styles.NowBtn}}"
        name="now_{{.ID}}"
      >
        Now
      </button>
      {{if .HasValue}}
      <button
        type="button"
        class="{{.Styles.ClearBtn}}"
        name="clear_{{.ID}}"
      >
        Clear
      </button>
      {{end}}
    </div>
  </div>
</div>
{{end}}
