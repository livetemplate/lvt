{{define "lvt:toggle:default:v1"}}
<label
  class="{{if .Disabled}}{{.Styles.LabelDisabled}}{{else}}{{.Styles.Label}}{{end}}"
  data-toggle="{{.ID}}"
>
  {{if .IsLabelLeft}}
  {{if .HasLabel}}
  <span class="{{.Styles.LabelText}}">{{.Label}}</span>
  {{end}}
  {{end}}

  {{/* Hidden input for form submission */}}
  <input
    type="checkbox"
    class="{{.Styles.Input}}"
    {{if .Name}}name="{{.Name}}"{{end}}
    {{if .Checked}}checked{{end}}
    {{if .Disabled}}disabled{{end}}
    {{if .Required}}required{{end}}
    value="{{.Value}}"
    lvt-change="toggle_{{.ID}}"
  />

  {{if .Styles.UseCustomTrack}}
  {{/* Toggle track */}}
  <div
    class="{{.Styles.Track}} {{.SizeClasses}} {{.TrackColorClass}}"
    lvt-click="toggle_{{.ID}}"
    role="switch"
    aria-checked="{{.Checked}}"
  >
    {{/* Toggle knob */}}
    <div
      class="{{.Styles.Knob}} {{.KnobSizeClasses}} {{.KnobTranslateClass}}"
    ></div>
  </div>
  {{end}}

  {{if .IsLabelRight}}
  {{if .HasLabel}}
  <div>
    <span class="{{.Styles.LabelText}}">{{.Label}}</span>
    {{if .HasDescription}}
    <p class="{{.Styles.Description}}">{{.Description}}</p>
    {{end}}
  </div>
  {{end}}
  {{end}}
</label>
{{end}}
