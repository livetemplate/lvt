{{define "lvt:toggle:checkbox:v1"}}
<label
  class="{{if .Disabled}}{{.Styles.LabelDisabled}}{{else}}{{.Styles.Label}}{{end}}"
  data-checkbox="{{.ID}}"
>
  {{if .Styles.UseCustomCheckbox}}
  {{/* Custom styled checkbox */}}
  <div class="{{.Styles.CheckboxWrap}}">
    <input
      type="checkbox"
      class="{{.Styles.Input}}"
      {{if .Name}}name="{{.Name}}"{{end}}
      {{if .Checked}}checked{{end}}
      {{if .Disabled}}disabled{{end}}
      {{if .Required}}required{{end}}
      value="{{.Value}}"
      lvt-on:change="toggle_{{.ID}}"
    />
    <div
      class="{{.Styles.CheckboxBox}} {{.CheckboxStateClass}}"
      lvt-on:click="toggle_{{.ID}}"
    >
      {{if .Checked}}
      <svg class="{{.Styles.CheckIcon}}" viewBox="0 0 12 12" fill="none">
        <path d="M2 6l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {{else if .Indeterminate}}
      <svg class="{{.Styles.CheckIcon}}" viewBox="0 0 12 12" fill="none">
        <path d="M2 6h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      {{end}}
    </div>
  </div>
  {{else}}
  {{/* Native checkbox */}}
  <input
    type="checkbox"
    class="{{.Styles.Input}}"
    {{if .Name}}name="{{.Name}}"{{end}}
    {{if .Checked}}checked{{end}}
    {{if .Disabled}}disabled{{end}}
    {{if .Required}}required{{end}}
    value="{{.Value}}"
    lvt-on:change="toggle_{{.ID}}"
  />
  {{end}}

  {{if .HasLabel}}
  <div class="{{.Styles.LabelTextWrap}}">
    <span class="{{.Styles.LabelText}}">{{.Label}}</span>
    {{if .HasDescription}}
    <p class="{{.Styles.Description}}">{{.Description}}</p>
    {{end}}
  </div>
  {{end}}
</label>
{{end}}
