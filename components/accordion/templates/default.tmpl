{{define "lvt:accordion:default:v1"}}
<div class="{{.Styles.Root}}" data-accordion="{{.ID}}">
  {{range .Items}}
  <div class="{{if .Disabled}}{{$.Styles.ItemDisabled}}{{end}}">
    <button
      type="button"
      id="accordion-header-{{$.ID}}-{{.ID}}"
      class="{{$.Styles.Header}} {{if .Disabled}}cursor-not-allowed{{end}}"
      lvt-click="toggle_accordion_{{$.ID}}"
      lvt-data-item="{{.ID}}"
      aria-expanded="{{$.IsOpen .ID}}"
      aria-controls="accordion-content-{{$.ID}}-{{.ID}}"
      {{if .Disabled}}disabled{{end}}
    >
      <span class="flex items-center">
        {{if .Icon}}<span class="{{$.Styles.HeaderIcon}}">{{.Icon}}</span>{{end}}
        {{.Title}}
      </span>
      <svg
        class="{{$.Styles.ChevronIcon}} {{if $.IsOpen .ID}}{{$.Styles.ChevronOpen}}{{end}}"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    {{if $.IsOpen .ID}}
    <div
      id="accordion-content-{{$.ID}}-{{.ID}}"
      class="{{$.Styles.Content}}"
      role="region"
      aria-labelledby="accordion-header-{{$.ID}}-{{.ID}}"
    >
      {{.Content}}
    </div>
    {{end}}
  </div>
  {{end}}
</div>
{{end}}
