{{define "lvt:accordion:single:v1"}}
{{$c := .}}
<div class="{{$c.Styles.Root}}" data-accordion="{{$c.ID}}" data-single-open="true">
  {{range $c.Items}}
  <div{{if or $c.Styles.Item .Disabled}} class="{{$c.Styles.Item}}{{if .Disabled}} {{$c.Styles.ItemDisabled}}{{end}}"{{end}}>
    <button
      type="button"
      class="{{$c.Styles.Header}} {{if .Disabled}}cursor-not-allowed{{end}}"
      lvt-click="toggle_accordion_{{$c.ID}}"
      lvt-data-item="{{.ID}}"
      aria-expanded="{{$c.IsOpen .ID}}"
      aria-controls="accordion-content-{{$c.ID}}-{{.ID}}"
      {{if .Disabled}}disabled{{end}}
    >
      <span class="flex items-center">
        {{if .Icon}}<span class="{{$c.Styles.HeaderIcon}}">{{.Icon}}</span>{{end}}
        {{.Title}}
      </span>
      <svg
        class="{{$c.Styles.ChevronIcon}} {{if $c.IsOpen .ID}}{{$c.Styles.ChevronOpen}}{{end}}"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    {{if $c.IsOpen .ID}}
    <div
      id="accordion-content-{{$c.ID}}-{{.ID}}"
      class="{{$c.Styles.Content}}"
      role="region"
      aria-labelledby="accordion-header-{{$c.ID}}-{{.ID}}"
    >
      {{.Content}}
    </div>
    {{end}}
  </div>
  {{end}}
</div>
{{end}}
