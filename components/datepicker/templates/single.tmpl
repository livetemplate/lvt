{{define "lvt:datepicker:single:v1"}}
<style>[data-datepicker]:not(.open) [data-datepicker-panel]{display:none}</style>
<div class="{{.Styles.Root}}" data-datepicker="{{.ID}}"
     lvt-el:removeClass:on:click-away="open">
  <button
    type="button"
    class="{{.Styles.TriggerBtn}}"
    onclick="var r=this.closest('[data-datepicker]');r.classList.toggle('open');this.setAttribute('aria-expanded',r.classList.contains('open'))"
    aria-haspopup="dialog"
    aria-expanded="false"
  >
    <span class="{{.Styles.TriggerText}}">
      <span class="{{if not .Selected}}{{.Styles.Placeholder}}{{end}}">{{.DisplayValue}}</span>
      <svg class="{{.Styles.TriggerIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
      </svg>
    </span>
  </button>

  <div
    class="{{.Styles.Dropdown}}"
    data-datepicker-panel
    hidden
    role="dialog"
    aria-modal="true"
    aria-label="Choose date"
  >
    {{template "lvt:datepicker:calendar" .}}
  </div>
</div>
{{end}}

{{define "lvt:datepicker:calendar"}}
{{$c := .}}
<div class="{{$c.Styles.Calendar}}">
  <div class="{{$c.Styles.NavWrapper}}">
    <button
      type="button"
      class="{{$c.Styles.NavBtn}}"
      lvt-click="prev_month_{{$c.ID}}"
      aria-label="Previous month"
    >
      <svg class="{{$c.Styles.NavIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
      </svg>
    </button>
    <span class="{{$c.Styles.MonthLabel}}">
      {{$c.ViewMonth}} {{$c.ViewYear}}
    </span>
    <button
      type="button"
      class="{{$c.Styles.NavBtn}}"
      lvt-click="next_month_{{$c.ID}}"
      aria-label="Next month"
    >
      <svg class="{{$c.Styles.NavIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>

  <div class="{{$c.Styles.WeekdayGrid}}">
    {{range $c.WeekdayNames}}
    <div class="{{$c.Styles.Weekday}}">{{.}}</div>
    {{end}}
  </div>

  {{range $c.CalendarWeeks}}
  <div class="{{$c.Styles.WeekGrid}}">
    {{range .}}
    <button
      type="button"
      class="{{$c.Styles.DayBtn}} {{if not .InMonth}}{{$c.Styles.DayOutMonth}}{{else if .IsDisabled}}{{$c.Styles.DayDisabled}}{{else if .IsSelected}}{{$c.Styles.DaySelected}}{{else if .IsToday}}{{$c.Styles.DayToday}}{{else}}{{$c.Styles.DayDefault}}{{end}}"
      {{if and .InMonth (not .IsDisabled)}}
      lvt-click="select_date_{{$c.ID}}"
      lvt-data-date="{{.DateString}}"
      {{else}}
      disabled
      {{end}}
    >
      {{.Day}}
    </button>
    {{end}}
  </div>
  {{end}}

  <div class="{{$c.Styles.Footer}}">
    <button
      type="button"
      class="{{$c.Styles.TodayBtn}}"
      lvt-click="today_{{$c.ID}}"
    >
      Today
    </button>
    {{if $c.Selected}}
    <button
      type="button"
      class="{{$c.Styles.ClearBtn}}"
      lvt-click="clear_date_{{$c.ID}}"
    >
      Clear
    </button>
    {{end}}
  </div>
</div>
{{end}}
