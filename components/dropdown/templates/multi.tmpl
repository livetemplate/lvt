{{define "lvt:dropdown:multi:v1"}}
<div class="{{.Styles.Root}}" data-dropdown="{{.ID}}">
  <button
    type="button"
    class="{{.Styles.TriggerBtn}}"
    lvt-click="toggle_{{.ID}}"
    {{if .Disabled}}disabled{{end}}
    aria-haspopup="listbox"
    aria-expanded="{{.Open}}"
    aria-multiselectable="true"
  >
    <span class="{{.Styles.SelectedText}}">
      {{.DisplayText}}
    </span>
    <span class="{{.Styles.TriggerIconWrap}}">
      <svg class="{{.Styles.TriggerIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </span>
  </button>

  {{if .Open}}
  <div
    class="{{.Styles.Dropdown}}"
    lvt-click-away="close_{{.ID}}"
    lvt-focus-trap
    role="listbox"
    aria-multiselectable="true"
  >
    {{if .SelectedItems}}
    <div class="{{.Styles.Option}}">
      <span>{{len .SelectedItems}} selected</span>
      <button
        type="button"
        lvt-click="clear_all_{{.ID}}"
      >
        Clear all
      </button>
    </div>
    {{end}}
    {{range .Options}}
    <label
      class="{{$.Styles.Option}} {{if .Disabled}}{{$.Styles.OptionDisabled}}{{end}}"
      role="option"
      {{if .Disabled}}aria-disabled="true"{{end}}
      {{if $.IsSelected .Value}}aria-selected="true"{{end}}
    >
      <input
        type="checkbox"
        {{if $.IsSelected .Value}}checked{{end}}
        {{if .Disabled}}disabled{{end}}
        lvt-change="toggle_item_{{$.ID}}"
        lvt-data-value="{{.Value}}"
      />
      <span>{{.Label}}</span>
    </label>
    {{end}}
  </div>
  {{end}}
</div>
{{end}}
