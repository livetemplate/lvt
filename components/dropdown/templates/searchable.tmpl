{{define "lvt:dropdown:searchable:v1"}}
{{$c := .}}
<style>[data-dropdown]:not(.open) [data-dropdown-panel]{display:none}</style>
<div class="{{$c.Styles.Root}} {{if $c.Open}}open{{end}}" data-dropdown="{{$c.ID}}"
     lvt-el:removeClass:on:click-away="open">
  <div class="{{$c.Styles.SearchWrapper}}">
    <input
      type="text"
      class="{{$c.Styles.TriggerBtn}}"
      placeholder="{{$c.Placeholder}}"
      value="{{$c.Query}}"
      lvt-on:input="search_{{$c.ID}}"
      lvt-mod:debounce="150"
      onfocus="this.closest('[data-dropdown]').classList.add('open');this.setAttribute('aria-expanded','true')"
      {{if $c.Disabled}}disabled{{end}}
      autocomplete="off"
      aria-haspopup="listbox"
      aria-expanded="{{$c.Open}}"
      {{if $c.Open}}lvt-autofocus{{end}}
    />
    {{if $c.Query}}
    <button
      type="button"
      class="{{$c.Styles.ClearBtnWrap}}"
      name="clear_search_{{$c.ID}}"
    >
      <svg class="{{$c.Styles.TriggerIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    {{end}}
    <span class="{{$c.Styles.TriggerIconWrap}}">
      <svg class="{{$c.Styles.TriggerIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
      </svg>
    </span>
  </div>

  <div
    class="{{$c.Styles.Dropdown}}"
    data-dropdown-panel
    role="listbox"
  >
    {{$visibleOptions := $c.VisibleOptions}}
    {{if $visibleOptions}}
    {{range $visibleOptions}}
    <div
      class="{{$c.Styles.Option}} {{if .Disabled}}{{$c.Styles.OptionDisabled}}{{end}} {{if and $c.Selected (eq $c.Selected.Value .Value)}}{{$c.Styles.OptionSelected}}{{end}}"
      lvt-on:click="select_{{$c.ID}}"
      data-value="{{.Value}}"
      role="option"
      {{if .Disabled}}aria-disabled="true"{{end}}
      {{if and $c.Selected (eq $c.Selected.Value .Value)}}aria-selected="true"{{end}}
    >
      {{.Label}}
    </div>
    {{end}}
    {{else}}
    <div class="{{$c.Styles.Option}}">
      No results found
    </div>
    {{end}}
  </div>
</div>
{{end}}
