{{define "lvt:dropdown:default:v1"}}
{{$c := .}}
{{template "lvt:dropdown:panel-css"}}
<div class="{{$c.Styles.Root}}" data-dropdown="{{$c.ID}}"
     lvt-el:removeClass:on:click-away="open">
  <button
    type="button"
    class="{{$c.Styles.TriggerBtn}}"
    onclick="var r=this.closest('[data-dropdown]');r.classList.toggle('open');this.setAttribute('aria-expanded',r.classList.contains('open'))"
    {{if $c.Disabled}}disabled{{end}}
    aria-haspopup="listbox"
    aria-expanded="false"
  >
    <span class="{{$c.Styles.SelectedText}}">
      {{if $c.Selected}}{{$c.Selected.Label}}{{else}}{{$c.Placeholder}}{{end}}
    </span>
    <span class="{{$c.Styles.TriggerIconWrap}}">
      <svg class="{{$c.Styles.TriggerIcon}}" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </span>
  </button>

  <div
    class="{{$c.Styles.Dropdown}}"
    data-dropdown-panel
    lvt-focus-trap
    role="listbox"
  >
    {{range $c.Options}}
    <div
      class="{{$c.Styles.Option}} {{if .Disabled}}{{$c.Styles.OptionDisabled}}{{end}} {{if and $c.Selected (eq $c.Selected.Value .Value)}}{{$c.Styles.OptionSelected}}{{end}}"
      lvt-on:click="select_{{$c.ID}}"
      data-value="{{.Value}}"
      role="option"
      {{if .Disabled}}aria-disabled="true"{{end}}
      {{if and $c.Selected (eq $c.Selected.Value .Value)}}aria-selected="true"{{end}}
    >
      {{.Label}}
    </div>
    {{end}}
  </div>
</div>
{{end}}
