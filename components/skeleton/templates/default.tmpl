{{define "lvt:skeleton:default:v1"}}
{{$c := .}}
{{if $c.IsMultiLine}}
<div class="{{$c.Styles.MultiLineWrap}}" data-skeleton="{{$c.ID}}">
  {{range $c.LineIndices}}
  <div
    class="{{$c.Styles.Base}} {{$c.ShapeClass}} {{$c.AnimationClass}}"
    style="width: {{$c.Width}}; height: {{$c.Height}}"
  ></div>
  {{end}}
</div>
{{else}}
<div
  class="{{.Styles.Base}} {{.ShapeClass}} {{.AnimationClass}}"
  style="width: {{.Width}}; height: {{.Height}}"
  data-skeleton="{{.ID}}"
></div>
{{end}}
{{end}}
