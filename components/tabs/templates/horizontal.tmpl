{{define "lvt:tabs:horizontal:v1"}}
<div class="{{.Styles.Root}}" data-tabs="{{.ID}}">
  <div class="{{.Styles.TabList}}" role="tablist" aria-orientation="horizontal">
    <nav class="{{.Styles.Nav}}">
      {{range .Items}}
      <button
        type="button"
        class="{{$.Styles.Tab}} {{if eq $.ActiveID .ID}}{{$.Styles.TabActive}}{{else}}{{$.Styles.TabDefault}}{{end}} {{if .Disabled}}{{$.Styles.TabDisabled}}{{end}}"
        lvt-click="select_tab_{{$.ID}}"
        lvt-data-tab="{{.ID}}"
        role="tab"
        aria-selected="{{if eq $.ActiveID .ID}}true{{else}}false{{end}}"
        {{if .Disabled}}disabled aria-disabled="true"{{end}}
        {{if eq $.ActiveID .ID}}aria-current="page"{{end}}
      >
        {{if .Icon}}<span class="{{$.Styles.TabIcon}}">{{.Icon}}</span>{{end}}
        {{.Label}}
        {{if .Badge}}<span class="{{$.Styles.Badge}}">{{.Badge}}</span>{{end}}
      </button>
      {{end}}
    </nav>
  </div>
</div>
{{end}}
