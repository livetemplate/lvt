{{define "lvt:tabs:horizontal:v1"}}
{{$c := .}}
<div class="{{$c.Styles.Root}}" data-tabs="{{$c.ID}}">
  <div class="{{$c.Styles.TabList}}" role="tablist" aria-orientation="horizontal">
    <nav class="{{$c.Styles.Nav}}">
      {{range $c.Items}}
      <button
        type="button"
        class="{{$c.Styles.Tab}} {{if eq $c.ActiveID .ID}}{{$c.Styles.TabActive}}{{else}}{{$c.Styles.TabDefault}}{{end}} {{if .Disabled}}{{$c.Styles.TabDisabled}}{{end}}"
        name="select_tab_{{$c.ID}}"
        data-tab="{{.ID}}"
        role="tab"
        aria-selected="{{if eq $c.ActiveID .ID}}true{{else}}false{{end}}"
        {{if .Disabled}}disabled aria-disabled="true"{{end}}
        {{if eq $c.ActiveID .ID}}aria-current="page"{{end}}
      >
        {{if .Icon}}<span class="{{$c.Styles.TabIcon}}">{{.Icon}}</span>{{end}}
        {{.Label}}
        {{if .Badge}}<span class="{{$c.Styles.Badge}}">{{.Badge}}</span>{{end}}
      </button>
      {{end}}
    </nav>
  </div>
</div>
{{end}}
