{{define "lvt:tabs:vertical:v1"}}
{{$c := .}}
<div class="{{$c.Styles.VerticalRoot}}" data-tabs="{{$c.ID}}">
  <nav class="{{$c.Styles.VerticalNav}}" role="tablist" aria-orientation="vertical">
    {{range $c.Items}}
    <button
      type="button"
      class="{{$c.Styles.VerticalTab}} {{if eq $c.ActiveID .ID}}{{$c.Styles.TabActive}}{{else}}{{$c.Styles.TabDefault}}{{end}} {{if .Disabled}}{{$c.Styles.TabDisabled}}{{end}}"
      name="select_tab_{{$c.ID}}"
      data-tab="{{.ID}}"
      role="tab"
      aria-selected="{{if eq $c.ActiveID .ID}}true{{else}}false{{end}}"
      {{if .Disabled}}disabled aria-disabled="true"{{end}}
    >
      {{if .Icon}}<span class="{{$c.Styles.TabIcon}}">{{.Icon}}</span>{{end}}
      {{.Label}}
      {{if .Badge}}<span class="{{$c.Styles.Badge}}">{{.Badge}}</span>{{end}}
    </button>
    {{end}}
  </nav>
</div>
{{end}}
