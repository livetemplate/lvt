{{define "lvt:tabs:vertical:v1"}}
<div class="{{.Styles.VerticalRoot}}" data-tabs="{{.ID}}">
  <nav class="{{.Styles.VerticalNav}}" role="tablist" aria-orientation="vertical">
    {{range .Items}}
    <button
      type="button"
      class="{{$.Styles.VerticalTab}} {{if eq $.ActiveID .ID}}{{$.Styles.TabActive}}{{else}}{{$.Styles.TabDefault}}{{end}} {{if .Disabled}}{{$.Styles.TabDisabled}}{{end}}"
      lvt-click="select_tab_{{$.ID}}"
      lvt-data-tab="{{.ID}}"
      role="tab"
      aria-selected="{{if eq $.ActiveID .ID}}true{{else}}false{{end}}"
      {{if .Disabled}}disabled aria-disabled="true"{{end}}
    >
      {{if .Icon}}<span class="{{$.Styles.TabIcon}}">{{.Icon}}</span>{{end}}
      {{.Label}}
      {{if .Badge}}<span class="{{$.Styles.Badge}}">{{.Badge}}</span>{{end}}
    </button>
    {{end}}
  </nav>
</div>
{{end}}
