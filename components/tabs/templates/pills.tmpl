{{define "lvt:tabs:pills:v1"}}
<div class="{{.Styles.Root}}" data-tabs="{{.ID}}">
  <nav class="{{.Styles.PillsNav}}" role="tablist">
    {{range .Items}}
    <button
      type="button"
      class="{{$.Styles.PillTab}} {{if eq $.ActiveID .ID}}{{$.Styles.PillActive}}{{else}}{{$.Styles.PillDefault}}{{end}} {{if .Disabled}}{{$.Styles.PillDisabled}}{{end}}"
      lvt-click="select_tab_{{$.ID}}"
      lvt-data-tab="{{.ID}}"
      role="tab"
      aria-selected="{{if eq $.ActiveID .ID}}true{{else}}false{{end}}"
      {{if .Disabled}}disabled aria-disabled="true"{{end}}
    >
      {{if .Icon}}<span class="{{$.Styles.TabIcon}}">{{.Icon}}</span>{{end}}
      {{.Label}}
      {{if .Badge}}<span class="{{$.Styles.Badge}}">{{.Badge}}</span>{{end}}
    </button>
    {{end}}
  </nav>
</div>
{{end}}
