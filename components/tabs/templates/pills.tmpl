{{define "lvt:tabs:pills:v1"}}
{{$c := .}}
<div class="{{$c.Styles.Root}}" data-tabs="{{$c.ID}}">
  <nav class="{{$c.Styles.PillsNav}}" role="tablist">
    {{range $c.Items}}
    <button
      type="button"
      class="{{$c.Styles.PillTab}} {{if eq $c.ActiveID .ID}}{{$c.Styles.PillActive}}{{else}}{{$c.Styles.PillDefault}}{{end}} {{if .Disabled}}{{$c.Styles.PillDisabled}}{{end}}"
      name="select_tab_{{$c.ID}}"
      data-tab="{{.ID}}"
      role="tab"
      aria-selected="{{if eq $c.ActiveID .ID}}true{{else}}false{{end}}"
      {{if .Disabled}}disabled aria-disabled="true"{{end}}
    >
      {{if .Icon}}<span class="{{$c.Styles.TabIcon}}">{{.Icon}}</span>{{end}}
      {{.Label}}
      {{if .Badge}}<span class="{{$c.Styles.Badge}}">{{.Badge}}</span>{{end}}
    </button>
    {{end}}
  </nav>
</div>
{{end}}
