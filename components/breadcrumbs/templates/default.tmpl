{{define "lvt:breadcrumbs:default:v1"}}
<nav class="{{.Styles.Nav}} {{.SizeClass}}" aria-label="Breadcrumb" data-breadcrumbs="{{.ID}}">
  <ol class="{{.Styles.List}}">
    {{/* Home icon */}}
    {{if .ShowHome}}
    <li class="{{.Styles.ListItem}}">
      <a href="{{.HomeHref}}" class="{{.Styles.HomeLink}}">
        <svg class="{{.Styles.HomeIcon}}" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
        </svg>
        <span class="{{.Styles.SrOnly}}">Home</span>
      </a>
    </li>
    {{if .HasItems}}
    <li class="{{.Styles.ListItem}}">
      {{if .IsChevronSeparator}}
      <svg class="{{.Styles.SepIcon}}" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
      </svg>
      {{else}}
      <span class="{{.Styles.SepText}}">{{.SeparatorSymbol}}</span>
      {{end}}
    </li>
    {{end}}
    {{end}}

    {{/* Items */}}
    {{if .IsCollapsed}}
    {{/* First item */}}
    {{with index .Items 0}}
    <li class="{{$.Styles.ListItem}}">
      {{if .IsClickable}}
      <a href="{{.Href}}" class="{{.LinkClass}}">
        {{if .HasIcon}}<span class="{{$.Styles.ItemIcon}}">{{.Icon}}</span>{{end}}
        {{.Label}}
      </a>
      {{else}}
      <span class="{{.LinkClass}}" {{if .Current}}aria-current="page"{{end}}>
        {{if .HasIcon}}<span class="{{$.Styles.ItemIcon}}">{{.Icon}}</span>{{end}}
        {{.Label}}
      </span>
      {{end}}
    </li>
    {{end}}

    {{/* Ellipsis */}}
    <li class="{{.Styles.ListItem}}">
      {{if $.IsChevronSeparator}}
      <svg class="{{$.Styles.SepIcon}}" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
      </svg>
      {{else}}
      <span class="{{$.Styles.SepText}}">{{$.SeparatorSymbol}}</span>
      {{end}}
    </li>
    <li class="{{.Styles.ListItem}}">
      <span class="{{.Styles.Ellipsis}}">...</span>
    </li>

    {{/* Remaining visible items */}}
    {{$start := sub (len $.Items) (sub $.MaxVisible 1)}}
    {{range $idx, $item := slice $.Items $start}}
    <li class="{{$.Styles.ListItem}}">
      {{if $.IsChevronSeparator}}
      <svg class="{{$.Styles.SepIcon}}" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
      </svg>
      {{else}}
      <span class="{{$.Styles.SepText}}">{{$.SeparatorSymbol}}</span>
      {{end}}
    </li>
    <li class="{{$.Styles.ListItem}}">
      {{if $item.IsClickable}}
      <a href="{{$item.Href}}" class="{{$item.LinkClass}}">
        {{if $item.HasIcon}}<span class="{{$.Styles.ItemIcon}}">{{$item.Icon}}</span>{{end}}
        {{$item.Label}}
      </a>
      {{else}}
      <span class="{{$item.LinkClass}}" {{if $item.Current}}aria-current="page"{{end}}>
        {{if $item.HasIcon}}<span class="{{$.Styles.ItemIcon}}">{{$item.Icon}}</span>{{end}}
        {{$item.Label}}
      </span>
      {{end}}
    </li>
    {{end}}
    {{else}}
    {{/* All items visible */}}
    {{range $idx, $item := .Items}}
    {{if gt $idx 0}}
    <li class="{{$.Styles.ListItem}}">
      {{if $.IsChevronSeparator}}
      <svg class="{{$.Styles.SepIcon}}" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
      </svg>
      {{else}}
      <span class="{{$.Styles.SepText}}">{{$.SeparatorSymbol}}</span>
      {{end}}
    </li>
    {{end}}
    <li class="{{$.Styles.ListItem}}">
      {{if $item.IsClickable}}
      <a href="{{$item.Href}}" class="{{$item.LinkClass}}">
        {{if $item.HasIcon}}<span class="{{$.Styles.ItemIcon}}">{{$item.Icon}}</span>{{end}}
        {{$item.Label}}
      </a>
      {{else}}
      <span class="{{$item.LinkClass}}" {{if $item.Current}}aria-current="page"{{end}}>
        {{if $item.HasIcon}}<span class="{{$.Styles.ItemIcon}}">{{$item.Icon}}</span>{{end}}
        {{$item.Label}}
      </span>
      {{end}}
    </li>
    {{end}}
    {{end}}
  </ol>
</nav>
{{end}}
