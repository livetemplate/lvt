{{define "lvt:progress:default:v1"}}
<div class="{{.Styles.Root}}" data-progress="{{.ID}}" role="progressbar" aria-valuenow="{{.Value}}" aria-valuemin="0" aria-valuemax="{{.Max}}">
  {{if .ShowLabel}}
  <div class="{{.Styles.Header}}">
    <span class="{{.Styles.LabelText}}">{{if .Label}}{{.Label}}{{else}}Progress{{end}}</span>
    <span class="{{.Styles.ValueText}}">{{.PercentageStr}}</span>
  </div>
  {{end}}

  <div class="{{.Styles.Track}} {{.SizeClass}}">
    {{if .Indeterminate}}
    <div class="{{.ColorClass}} {{.SizeClass}} {{.Styles.Bar}} {{.Styles.BarIndeterminate}}"></div>
    {{else}}
    <div
      class="{{.ColorClass}} {{.SizeClass}} {{.Styles.Bar}} {{if .Striped}}{{.Styles.Striped}}{{end}} {{if .Animated}}{{.Styles.Animated}}{{end}}"
      style="width: {{.Percentage}}%"
    ></div>
    {{end}}
  </div>
</div>
{{end}}
