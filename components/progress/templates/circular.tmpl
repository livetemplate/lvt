{{define "lvt:progress:circular:v1"}}
<div class="{{.Styles.Root}}" data-progress="{{.ID}}" role="progressbar" aria-valuenow="{{.Value}}" aria-valuemin="0" aria-valuemax="{{.Max}}">
  <svg class="{{if .Indeterminate}}{{.Styles.SvgIndeterminate}}{{end}}" width="{{.Size}}" height="{{.Size}}">
    {{/* Background circle */}}
    <circle
      class="{{.Styles.TrackCircle}}"
      stroke="currentColor"
      stroke-width="{{.StrokeWidth}}"
      fill="none"
      cx="{{.Center}}"
      cy="{{.Center}}"
      r="{{.Radius}}"
    />
    {{/* Progress circle */}}
    <circle
      class="{{.ColorClass}} {{.Styles.BarCircle}}"
      stroke="currentColor"
      stroke-width="{{.StrokeWidth}}"
      stroke-linecap="round"
      fill="none"
      cx="{{.Center}}"
      cy="{{.Center}}"
      r="{{.Radius}}"
      stroke-dasharray="{{.Circumference}}"
      stroke-dashoffset="{{.DashOffset}}"
      transform="rotate(-90 {{.Center}} {{.Center}})"
    />
  </svg>
  {{if .ShowLabel}}
  <span class="{{.Styles.Label}}">{{.DisplayLabel}}</span>
  {{end}}
</div>
{{end}}
