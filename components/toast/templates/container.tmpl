{{define "lvt:toast:container:v1"}}
<div
  class="{{.Styles.Container}} {{.GetPositionClasses}} {{.Styles.ContainerWidth}}"
  data-toast-container="{{.ID}}"
  aria-live="polite"
  aria-atomic="true"
>
  {{range .VisibleMessages}}
  <div
    class="{{$.Styles.Toast}} {{$.GetTypeClasses .Type}}"
    role="alert"
    data-toast="{{.ID}}"
  >
    <div class="{{$.Styles.ToastInner}}">
      <div class="{{$.Styles.ToastLayout}}">
        {{if .Icon}}
        <div class="{{$.Styles.IconWrap}}">
          {{.Icon}}
        </div>
        {{end}}
        <div class="{{$.Styles.ContentWrap}}{{if .Icon}} {{$.Styles.ContentIcon}}{{end}}">
          {{if .Title}}
          <p class="{{$.Styles.Title}}">{{.Title}}</p>
          {{end}}
          {{if .Body}}
          <p class="{{$.Styles.Body}}{{if .Title}} {{$.Styles.BodyWithTitle}}{{end}}">{{.Body}}</p>
          {{end}}
        </div>
        {{if .Dismissible}}
        <div class="{{$.Styles.DismissWrap}}">
          <button
            type="button"
            class="{{$.Styles.DismissBtn}}"
            lvt-click="dismiss_toast_{{$.ID}}"
            lvt-data-toast="{{.ID}}"
            aria-label="Dismiss"
          >
            <svg class="{{$.Styles.DismissIcon}}" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
        {{end}}
      </div>
    </div>
  </div>
  {{end}}
</div>
{{end}}
