{{define "lvt:modal:default:v1"}}
<style>
  [data-modal] { position: fixed; inset: 0; z-index: 40; display: flex; align-items: center; justify-content: center; padding: 1rem; background: rgba(0,0,0,0.5); }
  [data-modal] button { width: auto; margin: 0; }
</style>
{{if .Open}}
<div class="{{.Styles.Root}}" data-modal="{{.ID}}" role="dialog" aria-modal="true">
  {{/* Overlay */}}
  <div
    class="{{.Styles.Overlay}}"
    {{if .CloseOnOverlay}}lvt-on:click="hide_{{.ID}}"{{end}}
    aria-hidden="true"
  ></div>

  {{/* Modal container */}}
  <div class="{{if .Centered}}{{.Styles.ContainerCentered}}{{else}}{{.Styles.ContainerTop}}{{end}}">
    {{/* Modal panel */}}
    <div
      class="{{.Styles.Panel}} {{.SizeClass}}"
      {{if .CloseOnEscape}}lvt-on:keydown="hide_{{.ID}}" lvt-key="Escape"{{end}}
    >
      {{/* Header */}}
      {{if .HasHeader}}
      <div class="{{.Styles.Header}}">
        {{if .HasTitle}}
        <h3 class="{{.Styles.Title}}">{{.Title}}</h3>
        {{else}}
        <div></div>
        {{end}}
        {{if .ShowClose}}
        <button
          type="button"
          class="{{.Styles.CloseBtn}}"
          name="hide_{{.ID}}"
          aria-label="Close"
        >
          <svg class="{{.Styles.CloseIcon}}" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        {{end}}
      </div>
      {{end}}

      {{/* Body */}}
      <div class="{{if .Scrollable}}{{.Styles.BodyScrollable}}{{else}}{{.Styles.Body}}{{end}}">
        {{/* Content slot - rendered by parent template */}}
      </div>

      {{/* Footer - can be added via nested template */}}
    </div>
  </div>
</div>
{{end}}
{{end}}
