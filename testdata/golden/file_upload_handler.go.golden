package gallery

import (
	"context"
	"fmt"
	"log"
	"math"
	"net/http"
	"os"
	"path"
	"sort"
	"strings"
	"time"

	"github.com/go-playground/validator/v10"
	"github.com/livetemplate/livetemplate"
	_ "github.com/livetemplate/lvt/components/styles/tailwind"
	"github.com/livetemplate/lvt/components/modal"
	"github.com/livetemplate/lvt/components/toast"
	"github.com/livetemplate/lvt/pkg/storage"
	"testmodule/database/models"
)

var validate = validator.New()

type GalleryItem = models.Gallery

type AddInput struct {
	Title string `json:"title" validate:"required,min=3"`
}

type UpdateInput struct {
	ID string `json:"id" validate:"required"`
	Title string `json:"title" validate:"required,min=3"`
}

type IDInput struct {
	ID string `json:"id" validate:"required"`
}

type SearchInput struct {
	Query string `json:"query"`
}

type SortInput struct {
	SortBy string `json:"sort_by"`
}

type PaginationInput struct {
	Page int `json:"page" validate:"required,min=1"`
}

// GalleryController is a singleton that holds dependencies (DB, logger, etc.)
type GalleryController struct {
	Queries *models.Queries
	Store   storage.Store
}

// GalleryState is pure data, cloned per session
type GalleryState struct {
	Title        string                `json:"title"`
	SearchQuery  string                `json:"search_query"`
	SortBy       string                `json:"sort_by"`
	FilteredGalleries  []GalleryItem `json:"filtered_gallerys"`
	CurrentPage  int                   `json:"current_page"`
	PageSize     int                   `json:"page_size"`
	TotalPages   int                   `json:"total_pages"`
	PaginatedGalleries []GalleryItem `json:"paginated_gallerys"`
	TotalCount   int                   `json:"total_count"`
	LastUpdated  string                `json:"last_updated"`
	EditingID    string                `json:"editing_id" lvt:"transient"`
	EditingGallery *GalleryItem   `json:"editing_gallery" lvt:"transient"`
	IsEditingMode bool                 `json:"is_editing_mode"` // For page mode: true when at /resource/:id/edit
	PaginationMode string              `json:"pagination_mode"` // "infinite", "load-more", "prev-next", "numbers"
	LoadedCount    int                 `json:"loaded_count"`    // For infinite/load-more modes
	HasMore        bool                `json:"has_more"`        // Whether more items available
	IsLoading      bool                `json:"is_loading"`      // Loading indicator
	CSSFramework    string              `json:"-"`               // CSS framework for templates
	DeleteConfirm   *modal.ConfirmModal `json:"delete_confirm"`
	PendingDeleteID string              `json:"pending_delete_id" lvt:"transient"`
	Toasts          *toast.Container    `json:"toasts"`
	// Sort reversion protection: morphdom can trigger spurious change events
	PrevSortBy   string                `json:"prev_sort_by" lvt:"transient"`   // Previous sort value before last change
	LastSortTime int64                 `json:"last_sort_time" lvt:"transient"` // Unix nano of last sort action
}

// Add handles the "add" action to create a new resource
func (c *GalleryController) Add(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	var input AddInput
	if err := ctx.BindAndValidate(&input, validate); err != nil {
		return state, err
	}

	now := time.Now()
	id := fmt.Sprintf("gallery-%d", now.UnixNano())
	// Process file uploads
	var photoVal, photoFilename, photoContentType string
	var photoSize int64
	if uploads := ctx.GetCompletedUploads("photo"); len(uploads) > 0 {
		entry := uploads[0]
		f, err := os.Open(entry.TempPath)
		if err != nil {
			return state, fmt.Errorf("failed to open uploaded file: %w", err)
		}
		defer f.Close()
		safeName := path.Base(strings.ReplaceAll(entry.ClientName, "\\", "/"))
		key := fmt.Sprintf("galleries/%s/%s", id, safeName)
		if err := c.Store.Save(dbCtx, key, f); err != nil {
			return state, fmt.Errorf("failed to save file: %w", err)
		}
		photoVal = c.Store.URL(key)
		photoFilename = entry.ClientName
		photoContentType = entry.ClientType
		photoSize = entry.ClientSize
	}
	var docVal, docFilename, docContentType string
	var docSize int64
	if uploads := ctx.GetCompletedUploads("doc"); len(uploads) > 0 {
		entry := uploads[0]
		f, err := os.Open(entry.TempPath)
		if err != nil {
			return state, fmt.Errorf("failed to open uploaded file: %w", err)
		}
		defer f.Close()
		safeName := path.Base(strings.ReplaceAll(entry.ClientName, "\\", "/"))
		key := fmt.Sprintf("galleries/%s/%s", id, safeName)
		if err := c.Store.Save(dbCtx, key, f); err != nil {
			return state, fmt.Errorf("failed to save file: %w", err)
		}
		docVal = c.Store.URL(key)
		docFilename = entry.ClientName
		docContentType = entry.ClientType
		docSize = entry.ClientSize
	}

	_, err := c.Queries.CreateGallery(dbCtx, models.CreateGalleryParams{
		ID:        id,
		Title: input.Title,
		Photo:            photoVal,
		PhotoFilename:    photoFilename,
		PhotoContentType: photoContentType,
		PhotoSize:         photoSize,
		Doc:            docVal,
		DocFilename:    docFilename,
		DocContentType: docContentType,
		DocSize:         docSize,
		CreatedAt: now,
	})
	if err != nil {
		return state, fmt.Errorf("failed to create gallery: %w", err)
	}

	state, err = c.loadGallerys(state, dbCtx)
	if err != nil {
		return state, err
	}
	state.Toasts.AddSuccess("Created", "Gallery created successfully")
	state.LastUpdated = formatTime()
	return state, nil
}

// Edit handles the "edit" action to start editing a resource
func (c *GalleryController) Edit(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	var input IDInput
	if err := ctx.BindAndValidate(&input, validate); err != nil {
		return state, err
	}

	// Find the item to edit
	gallerys, err := c.Queries.GetAllGalleries(dbCtx)
	if err != nil {
		return state, fmt.Errorf("failed to load gallerys: %w", err)
	}

	for _, item := range gallerys {
		if item.ID == input.ID {
			state.EditingID = input.ID
			itemCopy := item
			state.EditingGallery = &itemCopy
			break
		}
	}

	state.LastUpdated = formatTime()
	return state, nil
}

// Update handles the "update" action to save changes to a resource
func (c *GalleryController) Update(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	var input UpdateInput
	if err := ctx.BindAndValidate(&input, validate); err != nil {
		return state, err
	}
	// Process file uploads (only update file columns if new file uploaded)
	existing, err := c.Queries.GetGalleryByID(dbCtx, input.ID)
	if err != nil {
		return state, fmt.Errorf("failed to load existing gallery: %w", err)
	}
	photoVal := existing.Photo
	photoFilename := existing.PhotoFilename
	photoContentType := existing.PhotoContentType
	photoSize := existing.PhotoSize
	if uploads := ctx.GetCompletedUploads("photo"); len(uploads) > 0 {
		entry := uploads[0]
		f, err := os.Open(entry.TempPath)
		if err != nil {
			return state, fmt.Errorf("failed to open uploaded file: %w", err)
		}
		defer f.Close()
		safeName := path.Base(strings.ReplaceAll(entry.ClientName, "\\", "/"))
		key := fmt.Sprintf("galleries/%s/%s", input.ID, safeName)
		if err := c.Store.Save(dbCtx, key, f); err != nil {
			return state, fmt.Errorf("failed to save file: %w", err)
		}
		photoVal = c.Store.URL(key)
		photoFilename = entry.ClientName
		photoContentType = entry.ClientType
		photoSize = entry.ClientSize
	}
	docVal := existing.Doc
	docFilename := existing.DocFilename
	docContentType := existing.DocContentType
	docSize := existing.DocSize
	if uploads := ctx.GetCompletedUploads("doc"); len(uploads) > 0 {
		entry := uploads[0]
		f, err := os.Open(entry.TempPath)
		if err != nil {
			return state, fmt.Errorf("failed to open uploaded file: %w", err)
		}
		defer f.Close()
		safeName := path.Base(strings.ReplaceAll(entry.ClientName, "\\", "/"))
		key := fmt.Sprintf("galleries/%s/%s", input.ID, safeName)
		if err := c.Store.Save(dbCtx, key, f); err != nil {
			return state, fmt.Errorf("failed to save file: %w", err)
		}
		docVal = c.Store.URL(key)
		docFilename = entry.ClientName
		docContentType = entry.ClientType
		docSize = entry.ClientSize
	}
	err = c.Queries.UpdateGallery(dbCtx, models.UpdateGalleryParams{
		ID: input.ID,
		Title: input.Title,
		Photo:            photoVal,
		PhotoFilename:    photoFilename,
		PhotoContentType: photoContentType,
		PhotoSize:         photoSize,
		Doc:            docVal,
		DocFilename:    docFilename,
		DocContentType: docContentType,
		DocSize:         docSize,
	})
	if err != nil {
		return state, fmt.Errorf("failed to update gallery: %w", err)
	}

	// For page mode: Exit edit mode and stay on detail view
	state.IsEditingMode = false

	// Reload the updated resource
	state, err = c.loadGallerys(state, dbCtx)
	if err != nil {
		return state, err
	}

	// Close modal / clear editing state after successful save
	state.EditingID = ""
	state.EditingGallery = nil
	state.Toasts.AddSuccess("Updated", "Gallery updated successfully")
	state.LastUpdated = formatTime()
	return state, nil
}

// CancelEdit handles the "cancel_edit" action to cancel editing
func (c *GalleryController) CancelEdit(state GalleryState, _ *livetemplate.Context) (GalleryState, error) {
	state.EditingID = ""
	state.EditingGallery = nil
	state.LastUpdated = formatTime()
	return state, nil
}

// View handles the "view" action to view a resource
func (c *GalleryController) View(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	var input IDInput
	if err := ctx.BindAndValidate(&input, validate); err != nil {
		return state, err
	}

	// Find the item to view/edit
	gallerys, err := c.Queries.GetAllGalleries(dbCtx)
	if err != nil {
		return state, fmt.Errorf("failed to load gallerys: %w", err)
	}

	for _, item := range gallerys {
		if item.ID == input.ID {
			state.EditingID = input.ID
			itemCopy := item
			state.EditingGallery = &itemCopy
			break
		}
	}

	state.LastUpdated = formatTime()
	return state, nil
}

// Back handles the "back" action to return to list view
func (c *GalleryController) Back(state GalleryState, _ *livetemplate.Context) (GalleryState, error) {
	state.EditingID = ""
	state.EditingGallery = nil
	state.LastUpdated = formatTime()
	return state, nil
}
// RequestDelete handles the "request_delete" action to show the delete confirmation modal
func (c *GalleryController) RequestDelete(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	var input IDInput
	if err := ctx.BindAndValidate(&input, validate); err != nil {
		return state, err
	}

	state.PendingDeleteID = input.ID
	state.DeleteConfirm.Show()
	state.LastUpdated = formatTime()
	return state, nil
}

// ConfirmDelete handles the "confirm_delete" action from the confirmation modal
func (c *GalleryController) ConfirmDelete(state GalleryState, _ *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	if state.PendingDeleteID == "" {
		return state, nil
	}
	// Delete associated files from storage
	if existing, err := c.Queries.GetGalleryByID(dbCtx, state.PendingDeleteID); err == nil {
		if existing.Photo != "" {
			_ = c.Store.Delete(dbCtx, existing.Photo)
		}
		if existing.Doc != "" {
			_ = c.Store.Delete(dbCtx, existing.Doc)
		}
	}

	err := c.Queries.DeleteGallery(dbCtx, state.PendingDeleteID)
	if err != nil {
		return state, fmt.Errorf("failed to delete gallery: %w", err)
	}

	state.DeleteConfirm.Hide()
	state.PendingDeleteID = ""
	state.EditingID = ""
	state.EditingGallery = nil

	state, err = c.loadGallerys(state, dbCtx)
	if err != nil {
		return state, err
	}

	state.Toasts.AddSuccess("Deleted", "Gallery deleted successfully")
	state.LastUpdated = formatTime()
	return state, nil
}

// CancelDelete handles the "cancel_delete" action to close the confirmation modal
func (c *GalleryController) CancelDelete(state GalleryState, _ *livetemplate.Context) (GalleryState, error) {
	state.DeleteConfirm.Hide()
	state.PendingDeleteID = ""
	return state, nil
}

// DismissToastNotifications handles the "dismiss_toast_notifications" action
func (c *GalleryController) DismissToastNotifications(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	toastID := ctx.GetString("toast")
	if toastID != "" {
		state.Toasts.Dismiss(toastID)
	}
	return state, nil
}

// Search handles the "search" action to filter resources
func (c *GalleryController) Search(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	var input SearchInput
	if err := ctx.BindAndValidate(&input, validate); err != nil {
		return state, err
	}
	state.SearchQuery = input.Query
	// Reset infinite scroll when searching
	if state.PaginationMode == "infinite" || state.PaginationMode == "load-more" {
		state.LoadedCount = state.PageSize
	}

	state, err := c.loadGallerys(state, dbCtx)
	if err != nil {
		return state, err
	}

	state.LastUpdated = formatTime()
	return state, nil
}

// Sort handles the "sort" action to sort resources
func (c *GalleryController) Sort(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	var input SortInput
	if err := ctx.BindAndValidate(&input, validate); err != nil {
		return state, err
	}

	now := time.Now().UnixNano()

	// Detect and ignore spurious morphdom-triggered reversions:
	// If we receive a value that equals the previous value, and it's within 500ms of the last change,
	// this is likely a spurious event from morphdom updating the select element
	if state.LastSortTime > 0 {
		elapsed := now - state.LastSortTime
		elapsedMs := elapsed / 1_000_000
		if input.SortBy == state.PrevSortBy && elapsedMs < 500 {
			return state, nil
		}
	}

	// Track previous value and update
	state.PrevSortBy = state.SortBy
	state.SortBy = input.SortBy
	state.LastSortTime = now
	// Note: Don't reset LoadedCount when sorting - keep all loaded items visible
	// Just re-sort the existing items for better UX

	state, err := c.loadGallerys(state, dbCtx)
	if err != nil {
		return state, err
	}

	state.LastUpdated = formatTime()
	return state, nil
}

// NextPage handles the "next_page" action for pagination
func (c *GalleryController) NextPage(state GalleryState, _ *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	if state.CurrentPage < state.TotalPages {
		state.CurrentPage++
	}
	state, err := c.loadGallerys(state, dbCtx)
	if err != nil {
		return state, err
	}

	state.LastUpdated = formatTime()
	return state, nil
}

// PrevPage handles the "prev_page" action for pagination
func (c *GalleryController) PrevPage(state GalleryState, _ *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	if state.CurrentPage > 1 {
		state.CurrentPage--
	}
	state, err := c.loadGallerys(state, dbCtx)
	if err != nil {
		return state, err
	}

	state.LastUpdated = formatTime()
	return state, nil
}

// GotoPage handles the "goto_page" action to jump to a specific page
func (c *GalleryController) GotoPage(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	var input PaginationInput
	if err := ctx.BindAndValidate(&input, validate); err != nil {
		return state, err
	}
	if input.Page >= 1 && input.Page <= state.TotalPages {
		state.CurrentPage = input.Page
	}
	state, err := c.loadGallerys(state, dbCtx)
	if err != nil {
		return state, err
	}

	state.LastUpdated = formatTime()
	return state, nil
}

// LoadMore handles the "load_more" action for infinite scroll
func (c *GalleryController) LoadMore(state GalleryState, _ *livetemplate.Context) (GalleryState, error) {
	dbCtx := context.Background()

	if state.PaginationMode == "infinite" || state.PaginationMode == "load-more" {
		if state.HasMore && !state.IsLoading {
			state.IsLoading = true
			state.LoadedCount += state.PageSize
			var err error
			state, err = c.loadGallerys(state, dbCtx)
			if err != nil {
				return state, err
			}
			state.IsLoading = false
		}
	}

	state.LastUpdated = formatTime()
	return state, nil
}

// Mount is called when a new session is created or when page-mode navigation triggers a remount.
func (c *GalleryController) Mount(state GalleryState, ctx *livetemplate.Context) (GalleryState, error) {
	return c.loadGallerys(state, context.Background())
}

func (c *GalleryController) loadGallerys(state GalleryState, ctx context.Context) (GalleryState, error) {
	gallerys, err := c.Queries.GetAllGalleries(ctx)
	if err != nil {
		return state, fmt.Errorf("failed to load gallerys: %w", err)
	}

	if state.SearchQuery == "" {
		state.FilteredGalleries = gallerys
	} else {
		state.FilteredGalleries = []GalleryItem{}
		query := strings.ToLower(state.SearchQuery)
		for _, item := range gallerys {
			// Search across all text fields (skip file/image fields)
			if strings.Contains(strings.ToLower(item.Title), query) {
				state.FilteredGalleries = append(state.FilteredGalleries, item)
				continue
			}
		}
	}

	state.TotalCount = len(gallerys)
	state = applySorting(state)
	state = applyPagination(state)

	return state, nil
}

// applySorting sorts the filtered items in-place based on the SortBy field.
// Note: sort.Slice mutates the slice in place. This is safe because:
// 1. State is cloned per session via AsState (JSON serialization creates fresh slices)
// 2. The slice is populated fresh from the database in each load operation
// 3. State is passed by value and returned, not shared across sessions
func applySorting(state GalleryState) GalleryState {
	switch state.SortBy {
	case "title_asc":
		sort.Slice(state.FilteredGalleries, func(i, j int) bool {
			return strings.ToLower(state.FilteredGalleries[i].Title) < strings.ToLower(state.FilteredGalleries[j].Title)
		})
	case "title_desc":
		sort.Slice(state.FilteredGalleries, func(i, j int) bool {
			return strings.ToLower(state.FilteredGalleries[i].Title) > strings.ToLower(state.FilteredGalleries[j].Title)
		})
	case "oldest_first":
		sort.Slice(state.FilteredGalleries, func(i, j int) bool {
			return state.FilteredGalleries[i].CreatedAt.Before(state.FilteredGalleries[j].CreatedAt)
		})
	default:
		sort.Slice(state.FilteredGalleries, func(i, j int) bool {
			return state.FilteredGalleries[i].CreatedAt.After(state.FilteredGalleries[j].CreatedAt)
		})
	}
	return state
}

func applyPagination(state GalleryState) GalleryState {
	if state.PaginationMode == "infinite" || state.PaginationMode == "load-more" {
		return applyInfiniteScroll(state)
	}
	return applyPagedNavigation(state)
}

func applyInfiniteScroll(state GalleryState) GalleryState {
	// Initialize LoadedCount if not set
	if state.LoadedCount == 0 {
		state.LoadedCount = state.PageSize
	}

	if len(state.FilteredGalleries) == 0 {
		state.PaginatedGalleries = []GalleryItem{}
		state.HasMore = false
		return state
	}

	// Load items from 0 to LoadedCount
	end := state.LoadedCount
	if end > len(state.FilteredGalleries) {
		end = len(state.FilteredGalleries)
	}

	state.PaginatedGalleries = state.FilteredGalleries[0:end]
	state.HasMore = end < len(state.FilteredGalleries)
	return state
}

func applyPagedNavigation(state GalleryState) GalleryState {
	if len(state.FilteredGalleries) == 0 {
		state.TotalPages = 1
		state.CurrentPage = 1
		state.PaginatedGalleries = []GalleryItem{}
		return state
	}

	state.TotalPages = int(math.Ceil(float64(len(state.FilteredGalleries)) / float64(state.PageSize)))

	if state.CurrentPage < 1 {
		state.CurrentPage = 1
	}
	if state.CurrentPage > state.TotalPages {
		state.CurrentPage = state.TotalPages
	}

	start := (state.CurrentPage - 1) * state.PageSize
	end := start + state.PageSize
	if end > len(state.FilteredGalleries) {
		end = len(state.FilteredGalleries)
	}

	state.PaginatedGalleries = state.FilteredGalleries[start:end]
	return state
}

func formatTime() string {
	return time.Now().Format("2006-01-02 15:04:05")
}

// Handler creates an http.Handler for this resource
func Handler(queries *models.Queries, store storage.Store) http.Handler {
	// Controller is a singleton that holds dependencies
	controller := &GalleryController{
		Queries: queries,
		Store:   store,
	}

	// Initial state is pure data, cloned per session
	initialState := &GalleryState{
		Title:          "Gallery Management",
		CurrentPage:    1,
		PageSize:       20,
		PaginationMode: "infinite",
		LoadedCount:    20,
		LastUpdated:    formatTime(),
		CSSFramework:   "tailwind",
	}
	initialState.DeleteConfirm = modal.NewConfirm("delete",
		modal.WithConfirmTitle("Delete Gallery"),
		modal.WithConfirmMessage("Are you sure you want to delete this gallery? This action cannot be undone."),
		modal.WithConfirmDestructive(true),
	)
	initialState.Toasts = toast.New("notifications",
		toast.WithPosition(toast.TopRight),
		toast.WithMaxVisible(3),
	)

	baseTmpl := livetemplate.Must(livetemplate.New("gallery",
		livetemplate.WithDevMode(false),
		livetemplate.WithComponentTemplates(
			modal.Templates(),
			toast.Templates(),
		),
		livetemplate.WithUpload("photo", livetemplate.UploadConfig{
			Accept:     []string{"image/*"},
			MaxEntries: 1,
			MaxFileSize: 10 << 20, // 10 MB
			AutoUpload: true,
		}),
		livetemplate.WithUpload("doc", livetemplate.UploadConfig{
			Accept:     []string{"*/*"},
			MaxEntries: 1,
			MaxFileSize: 10 << 20, // 10 MB
			AutoUpload: true,
		}),
	))
	if _, err := baseTmpl.ParseFiles("app/gallery/gallery.tmpl"); err != nil {
		log.Fatalf("Failed to parse template: %v", err)
	}
	// Modal mode: clone template per request
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		tmpl, err := baseTmpl.Clone()
		if err != nil {
			log.Printf("Failed to clone template: %v", err)
			http.Error(w, "Internal server error", http.StatusInternalServerError)
			return
		}
		tmpl.Handle(controller, livetemplate.AsState(initialState)).ServeHTTP(w, r)
	})
}
